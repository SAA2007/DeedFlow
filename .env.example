# DeedFlow — Environment Variables
# Copy to .env and fill in values

# PostgreSQL connection
DATABASE_URL=postgresql://deedflow_user:your_password_here@localhost:5432/deedflow

# JWT secrets (generate with: openssl rand -base64 48)
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# Server
PORT=3001
NODE_ENV=development

# CORS (production only)
# ALLOWED_ORIGIN=https://myramadan.duckdns.org
